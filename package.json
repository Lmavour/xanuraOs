{
  "name": "android-os-web",
  "version": "1.0.0",
  "description": "A modular, web-based Android OS interface with file management, media viewing, and system monitoring capabilities",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint public/js/*.js public/app/**/*.js",
    "docs": "jsdoc -c jsdoc.conf.json",
    "clean": "rm -rf node_modules package-lock.json",
    "setup": "npm install && mkdir -p ../main-data"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^2.1.0",
    "systeminformation": "^5.21.15"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jsdoc": "^4.0.2",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "android",
    "os",
    "web",
    "dashboard",
    "file-manager",
    "media-player",
    "system-monitoring",
    "modular",
    "javascript",
    "nodejs",
    "express"
  ],
  "author": {
    "name": "Batara",
    "email": "batara@example.com",
    "url": "https://github.com/batara/android-os-web"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/batara/android-os-web.git"
  },
  "bugs": {
    "url": "https://github.com/batara/android-os-web/issues"
  },
  "homepage": "https://github.com/batara/android-os-web#readme",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
